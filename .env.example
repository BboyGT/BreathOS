# Database - SQLite for local dev. Change to postgresql://... for production.
DATABASE_URL="file:./db/breatheos.db"

# NextAuth - run `openssl rand -base64 32` to generate NEXTAUTH_SECRET.
NEXTAUTH_URL="http://localhost:3333"
NEXTAUTH_SECRET="your-secret-here-run-openssl-rand-base64-32"

# Magic-link email (SMTP). For local dev use Ethereal https://ethereal.email/
EMAIL_SERVER_HOST="smtp.ethereal.email"
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER="your-ethereal-user@ethereal.email"
EMAIL_SERVER_PASSWORD="your-ethereal-password"
EMAIL_FROM="BreatheOS <noreply@breatheos.app>"

# WebSocket server URL (Breathe Together feature)
NEXT_PUBLIC_WS_URL="ws://localhost:4001"

# Paystack checkout
PAYSTACK_SECRET_KEY="sk_test_replace_with_real_key"
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY="pk_test_replace_with_real_key"
NEXT_PUBLIC_APP_URL="http://localhost:3333"

# Supabase subscription source of truth
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="replace_with_real_service_role_key"
